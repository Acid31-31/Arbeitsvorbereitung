<Window x:Class="GeoArbeitsvorbereitung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GEO Arbeitsvorbereitung"
        Width="1100" Height="780" MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI" FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Title bar ════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#007ACC" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="⚙" FontSize="18" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="GEO Arbeitsvorbereitung"
                               FontSize="16" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Suchordner-Auswahl"
                            Command="{Binding OpenSearchFoldersCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"/>
                    <Button Content="Speicherordner-Auswahl"
                            Command="{Binding OpenOutputFoldersCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"/>
                    <Button Content="Excel-Datei auswählen"
                            Command="{Binding SelectLagerBestandExcelCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"/>
                    <Button Content="Lagerbestand (Excel)"
                            Command="{Binding OpenLagerBestandCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Main content ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Workflow area -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── Section: Suche ───────────────────────────────────── -->
                    <Border Background="{StaticResource SectionBg}" CornerRadius="4"
                            Margin="0,0,0,12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="🔍 Suche nach GEO-Datei"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <Label Content="Zeichnungsnummer / Suchbegriff"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DrawingNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="Suchen"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SearchCommand}"/>
                            </Grid>

                            <Border Visibility="{Binding HasFoundFiles, Converter={StaticResource BoolToVis}}"
                                    Background="#1A3A1A" BorderBrush="#2D6B2D" BorderThickness="1"
                                    CornerRadius="3" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Trefferliste (alle passenden GEO-Dateien)"
                                               Foreground="{StaticResource TextSuccess}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>

                                    <ListBox ItemsSource="{Binding FoundFiles}"
                                             SelectedItem="{Binding FoundFile, Mode=TwoWay}"
                                             Height="200"
                                             Background="#122612"
                                             BorderBrush="#2D6B2D"
                                             BorderThickness="1">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="6" BorderBrush="#244F24" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding FullPath}" FontSize="11" Foreground="#9E9E9E" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding LastWriteTime, StringFormat='dd.MM.yyyy HH:mm:ss'}"
                                                                   FontSize="11"
                                                                   Foreground="#9E9E9E"
                                                                   Margin="10,0,0,0"
                                                                   VerticalAlignment="Top"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SectionBg}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="📦 Lagerbestand (Excel)"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding LagerBestandStatus}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               Margin="0,0,0,8"/>

                                    <DataGrid ItemsSource="{Binding LagerBestandTreffer}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              Height="170"
                                              BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Zeichnungsnummer" Binding="{Binding Zeichnungsnummer}" Width="2*"/>
                                            <DataGridTextColumn Header="Material" Binding="{Binding Material}" Width="*"/>
                                            <DataGridTextColumn Header="Bestand" Binding="{Binding Bestand}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Section: Stückzahl & Ablegen ─────────────────── -->
                    <Border Background="{StaticResource SectionBg}" CornerRadius="4"
                            Margin="0,0,0,12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="📋 Stückzahl ändern &amp; ablegen"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <Label Content="Neue Stückzahl"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Content="Kopie erstellen &amp; ablegen"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding CreateCopyCommand}"
                                        HorizontalAlignment="Left"/>
                            </Grid>

                            <TextBlock Text="Die Stückzahl im Dateinamen wird ersetzt (z. B. 3x → 10x)."
                                       FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Das Original wird niemals verändert oder überschrieben."
                                       FontSize="11" Foreground="{StaticResource TextSecondary}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Section: Status / Log ──────────────────────────── -->
                    <Border Background="{StaticResource SectionBg}" CornerRadius="4" Padding="16">
                        <StackPanel>
                            <TextBlock Text="📝 Protokoll"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="3" Padding="10" Height="160">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding StatusLog, Mode=OneWay}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             Foreground="{StaticResource TextSecondary}"
                                             Padding="0"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right: Preview panel -->
            <Border Grid.Column="2" Background="{StaticResource SectionBg}" CornerRadius="4" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding PreviewTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Button Grid.Row="1"
                            Content="Im GEO Viewer öffnen"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding OpenInGeoViewerCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"/>

                    <TextBox Grid.Row="2"
                             Text="{Binding PreviewContent, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Segoe UI"
                             FontSize="12"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
