<Window x:Class="GeoArbeitsvorbereitung.Dialogs.SearchFoldersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Suchordner-Auswahl"
        Width="900" Height="640"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        Foreground="#CCCCCC"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderTextBlock"
                   Grid.Row="0"
                   Text="Suchordner auswählen (mindestens 10 Plätze)"
                   FontSize="15" FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FolderEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <RadioButton Grid.Column="0"
                                         GroupName="FolderPick"
                                         IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3C3C3C"
                                     Foreground="#CCCCCC"
                                     BorderBrush="#555555"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     Margin="0,0,8,0"/>

                            <Button Grid.Column="2"
                                    Content="Durchsuchen…"
                                    Tag="{Binding}"
                                    Click="BrowseFolder_Click"
                                    Margin="0,0,8,0"
                                    Padding="12,6"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding IndexLabel}"
                                       Foreground="#9E9E9E"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Abbrechen" Click="Cancel_Click" Margin="0,0,10,0" Padding="16,7"/>
            <Button Content="Auswahl übernehmen" Click="Apply_Click" Padding="16,7" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
